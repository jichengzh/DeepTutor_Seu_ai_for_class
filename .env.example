# ==============================================================================
# DeepTutor 环境配置 - 阿里云 DashScope
# ==============================================================================

# ==============================================================================
# 服务器端口
# ==============================================================================
BACKEND_PORT=8001
FRONTEND_PORT=3782

# ==============================================================================
# LLM 配置 - 阿里云通义千问
# ==============================================================================
LLM_BINDING=openai
LLM_MODEL=qwen-plus
LLM_API_KEY=sk-944df3acefa4495aa4b759d3bde51309
LLM_HOST=https://dashscope.aliyuncs.com/compatible-mode/v1

# ==============================================================================
# Embedding 配置 - 阿里云文本向量
# ==============================================================================
EMBEDDING_BINDING=openai
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_API_KEY=sk-944df3acefa4495aa4b759d3bde51309
EMBEDDING_HOST=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_DIMENSION=1024

# ==============================================================================
# TTS 配置（可选，暂不启用）
# ==============================================================================
# TTS_BINDING=openai
# TTS_MODEL=tts-1
# TTS_API_KEY=
# TTS_URL=https://api.openai.com/v1
# TTS_VOICE=alloy

# ==============================================================================
# 搜索配置（可选）
# ==============================================================================
# SEARCH_PROVIDER=perplexity
# SEARCH_API_KEY=

# ==============================================================================
# 云端部署配置（本地运行无需填写）
# ==============================================================================
# NEXT_PUBLIC_API_BASE_EXTERNAL=
# NEXT_PUBLIC_API_BASE=

# ==============================================================================
# 其他配置
# ==============================================================================
DISABLE_SSL_VERIFY=false

# HuggingFace 镜像（国内推荐）
# HF_ENDPOINT=https://hf-mirror.com
# HF_HOME=/app/data/hf